{
    "manifest_version": 3,
    "name": "VELOX Student Monitor",
    "version": "1.0",
    "description": "Real-time student engagement monitoring for VELOX system.",
    "permissions": [
        "activeTab",
        "scripting",
        "storage",
        "tabs"
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "http://localhost:8001/*",
        "*://meet.google.com/*",
        "*://zoom.us/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": [
                "*://meet.google.com/*",
                "*://zoom.us/*"
            ],
            "js": [
                "content.js"
            ],
            "run_at": "document_idle"
        }
    ],
    "action": {
        "default_popup": "popup.html",
        "default_title": "VELOX Monitor"
    },
    "web_accessible_resources": [
        {
            "matches": [
                "<all_urls>"
            ],
            "resources": [
                "popup.html",
                "vision_bundle.mjs",
                "wasm/vision_wasm_internal.js",
                "wasm/vision_wasm_internal.wasm"
            ]
        }
    ],
    "content_security_policy": {
        "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
    }
}